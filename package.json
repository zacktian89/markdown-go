{
  "name": "markdown-go-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace ./packages/markdown-go-cli",
    "build": "npm run build --workspace ./packages/markdown-go-cli",
    "typecheck": "npm run typecheck --workspace ./packages/markdown-go-cli",
    "pack:cli": "npm pack --workspace ./packages/markdown-go-cli",
    "verify:install": "node ./packages/markdown-go-cli/dist/cli.js README.md",
    "verify:skill-install": "node ./packages/markdown-go-cli/dist/cli.js install-skill --tool codex --dry-run",
    "release:check": "npm run typecheck && npm run pack:cli"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zacktian89/markdown-go.git"
  },
  "homepage": "https://github.com/zacktian89/markdown-go#readme",
  "bugs": {
    "url": "https://github.com/zacktian89/markdown-go/issues"
  },
  "author": "Zack",
  "version": "1.1.1"
}

